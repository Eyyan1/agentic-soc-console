# Django
SECRET_KEY=replace-with-a-random-secret-key

# Local demo mode
ASF_LOCAL_SIRP=1
ASF_ENABLE_BACKGROUND_SERVICES=1
ASF_FAKE_LLM=1
ASF_DISABLE_EMBEDDINGS=1

# Local file-backed SOC storage
# For local runs, leaving this unset falls back to <repo>/.runtime
# For Railway demo deployments, set this to /data
ASF_LOCAL_DATA_DIR=

# Backend service endpoints
REDIS_URL=redis://:redis-stack-password-for-agentic-soc-platform@localhost:6379/
QDRANT_URL=http://localhost:6333

# Optional OpenAI-compatible config
# Leave as a placeholder for local fake-LLM mode
OPENAI_API_KEY=sk-local-placeholder
